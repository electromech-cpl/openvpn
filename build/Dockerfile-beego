# Define architecture and platform dynamically
ARG ARCH
ARG PLATFORM
ARG BEEIMAGE
ARG MAINTAINER
ARG VERSION

# Set the maintainer label dynamically
LABEL maintainer=$MAINTAINER
LABEL version=$VERSION

# Use the beego base image passed from build.sh
FROM $BEEIMAGE

# Set the working directory to /beego
WORKDIR /beego

# Install dependencies based on the chosen image
RUN apt-get update && apt-get install git musl-tools -y

# Enable go modules
ENV GO111MODULE=on
ENV CGO_ENABLED=1

# Copy the go.mod and go.sum files to the container
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Install the beego and bee packages
RUN go install github.com/beego/bee/v2@develop

# Set the working directory to /app and clone the new openvpn repository
WORKDIR /app

# Clone the new openvpn repo (using the updated repo URL)
RUN git clone https://github.com/electromech-cpl/openvpn.git

# Set the working directory back to /
WORKDIR /
